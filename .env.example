# ============================================
# Film Connoisseur - Environment Variables
# ============================================
# Copy this file to .env and fill in your real values:
#   cp .env.example .env
#
# NEVER commit .env to version control!
# ============================================

# TMDB API Key - Get from https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# OMDb API Key - Get from https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=your_omdb_api_key_here

# Anthropic Claude API Key - Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude Model (optional, defaults to claude-sonnet-4-20250514)
CLAUDE_MODEL=claude-sonnet-4-20250514

# Database path (optional, defaults to movie_cache.db)
DATABASE_PATH=movie_cache.db

# ============================================
# Production / Deployment Settings
# ============================================

# Environment: development | production
ENVIRONMENT=development

# Allowed frontend origins for CORS (comma-separated)
# In development, defaults to http://localhost:3005,http://localhost:5173
# In production, set to your deployed frontend URL
ALLOWED_ORIGINS=http://localhost:3005,http://localhost:5173

# Beta access password (required for production)
BETA_PASSWORD=your_beta_password_here

# Admin password for sensitive endpoints (expand-pool, rebuild, etc.)
ADMIN_PASSWORD=your_admin_password_here

# JWT secret for token signing
JWT_SECRET=your_random_jwt_secret_here

# Rate limiting (requests per minute per IP)
RATE_LIMIT_GENERAL=60
RATE_LIMIT_AI=20
