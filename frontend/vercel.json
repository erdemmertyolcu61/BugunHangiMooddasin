{
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://bug-nhangimooddas-n-production.up.railway.app/api/:path*" },
    { "source": "/uploads/:path*", "destination": "https://bug-nhangimooddas-n-production.up.railway.app/uploads/:path*" },
    { "source": "/((?!assets/|.*\\.[a-zA-Z0-9]+$).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
